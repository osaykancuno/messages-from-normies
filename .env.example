SUPABASE_URL=https://your-project-id.supabase.co
# Use the SERVICE_ROLE key, not the anon key.
# The blocks table has Row Level Security enabled with no public policies,
# so the anon key cannot read or write it. Only service_role bypasses RLS.
# Find it at: Supabase dashboard > Project Settings > API > service_role
SUPABASE_KEY=your-service-role-key
PORT=3000
